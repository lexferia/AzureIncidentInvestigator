{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System.Net.Http.HttpClient": "Warning",
        "Azure": "Warning"
      }
    }
  },
  "UptimeRobot": {
    "BaseUrl": "https://api.uptimerobot.com/v2/",
    "TimeoutSeconds": 10,
    "CacheTtlSeconds": 60
  },
  "AppInsights": {
    "WorkspaceId": "00000000-0000-0000-0000-000000000000",
    "MaxQueryWindowDays": 7,
    "QueryTimeoutSeconds": 20,
    "TelemetryColumns": {
      "ClientIp": [ "customDimensions:Client IP Address", "builtIn:client_IP" ],
      "UserAgent": [ "customDimensions:User-Agent" ],
      "Country": [ "builtIn:client_CountryOrRegion" ]
    }
  },
  "AppServicePlans": {
    "AllowedResourceIds": [],
    "MonitorMappings": {},
    "CpuWarnThreshold": 80,
    "MemoryWarnThreshold": 80
  },
  "AppServiceSites": {
    "AllowedResourceIds": [],
    "MonitorMappings": {}
  },
  "Databases": {
    "Allowed": [],
    "CpuWarnThreshold": 75,
    "ConnectionFailWarnPerMinute": 10,
    "MonitorMappings": {}
  },
  "Reports": {
    "OutputDirectory": "%TEMP%\\AzureIncidentInvestigator\\reports",
    "KnownHosts": []
  },
  "RateLimits": { "PerToolPerMinute": 30 }
}
